NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
# Optional: Kommagetrennte Hostnamen für Diagnose-Logging beim Passwort-Reset.
# Beispiel: localhost,mental-faircare.de,www.mental-faircare.de
NEXT_PUBLIC_ALLOWED_AUTH_REDIRECT_HOSTS=
# Serverseitiges Pendant (falls nur serverseitig gesetzt werden soll):
APP_ALLOWED_AUTH_REDIRECT_HOSTS=
# Optional nur für lokale/Preview-Tests:
# TEST_EMAIL_OVERRIDE=test@example.com
TEST_EMAIL_OVERRIDE=
MAIL_PROVIDER=resend
RESEND_API_KEY=
SENDGRID_API_KEY=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternativ zur FIREBASE_PRIVATE_KEY:
FIREBASE_PRIVATE_KEY_BASE64=
# Alternativ zu FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY:
FIREBASE_SERVICE_ACCOUNT_PATH=
# Für MAIL_PROVIDER=resend muss MAIL_FROM auf @mail.mental-faircare.de enden.
# Beispiel: FairCare <noreply@mail.mental-faircare.de> oder FairCare <invite@mail.mental-faircare.de>
MAIL_FROM=FairCare <noreply@mail.mental-faircare.de>

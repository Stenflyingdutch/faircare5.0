rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserProfileExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profileIsSuperuser(data) {
      return ('isSuperuser' in data) && data.isSuperuser == true;
    }

    function isActiveAccount() {
      return currentUserProfileExists() && (
        !('accountStatus' in currentUserProfile().data) ||
        currentUserProfile().data.accountStatus == 'active'
      );
    }

    function isAdmin() {
      return currentUserProfileExists() &&
        currentUserProfile().data.adminRole == 'admin' &&
        isActiveAccount();
    }

    function isSuperuser() {
      return currentUserProfileExists() &&
        profileIsSuperuser(currentUserProfile().data) &&
        isActiveAccount();
    }

    function familyDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId));
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function userDocExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function userAccountActive(userId) {
      return userDocExists(userId) && (
        !('accountStatus' in userDoc(userId).data) ||
        userDoc(userId).data.accountStatus == 'active'
      );
    }

    function hasSharedFamilyAccessToUserProfile(targetUserId) {
      return isActiveAccount()
        && userAccountActive(targetUserId)
        && currentUserProfileExists()
        && ('familyId' in currentUserProfile().data)
        && (currentUserProfile().data.familyId is string)
        && currentUserProfile().data.familyId.size() > 0
        && exists(/databases/$(database)/documents/families/$(currentUserProfile().data.familyId))
        && isFamilyMember(currentUserProfile().data.familyId)
        && (
          familyDoc(currentUserProfile().data.familyId).data.initiatorUserId == targetUserId ||
          familyDoc(currentUserProfile().data.familyId).data.partnerUserId == targetUserId
        );
    }

    function isFamilyMember(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId)) && (
        familyDoc(familyId).data.initiatorUserId == request.auth.uid ||
        familyDoc(familyId).data.partnerUserId == request.auth.uid
      );
    }

    function taskVisibleToCurrentUser() {
      return !('visibleToUserIds' in resource.data)
        || resource.data.visibleToUserIds.size() == 0
        || resource.data.visibleToUserIds.hasAny([request.auth.uid]);
    }

    function taskVisibleToCurrentUserInRequest() {
      return !('visibleToUserIds' in request.resource.data)
        || request.resource.data.visibleToUserIds.size() == 0
        || request.resource.data.visibleToUserIds.hasAny([request.auth.uid]);
    }

    function familyResultsUnlocked(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId)) &&
        familyDoc(familyId).data.resultsUnlocked == true;
    }

    function familySharedResultsOpened(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId)) &&
        familyDoc(familyId).data.sharedResultsOpened == true;
    }

    match /users/{userId} {
      // Permit the first self-read during signup before the profile document exists.
      allow read: if (isSelf(userId) && (
        !exists(/databases/$(database)/documents/users/$(userId)) ||
        isActiveAccount()
      )) || isAdmin() || hasSharedFamilyAccessToUserProfile(userId);
      allow create: if isSelf(userId)
        && !('adminRole' in request.resource.data)
        && !('isSuperuser' in request.resource.data)
        && !('accountStatus' in request.resource.data);
      allow update: if (
        isSelf(userId) &&
        isActiveAccount() &&
        request.resource.data.adminRole == resource.data.adminRole &&
        profileIsSuperuser(request.resource.data) == profileIsSuperuser(resource.data) &&
        request.resource.data.accountStatus == resource.data.accountStatus
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    match /families/{familyId} {
      allow read: if isActiveAccount() && (
        resource.data.initiatorUserId == request.auth.uid ||
        resource.data.partnerUserId == request.auth.uid
      );
      allow create: if isActiveAccount() && request.resource.data.initiatorUserId == request.auth.uid;
      allow update: if isAdmin() || (isActiveAccount() && (
        resource.data.initiatorUserId == request.auth.uid ||
        (
          resource.data.partnerUserId == request.auth.uid &&
          request.resource.data.resultsUnlocked == resource.data.resultsUnlocked &&
          request.resource.data.unlockedBy == resource.data.unlockedBy &&
          request.resource.data.unlockedAt == resource.data.unlockedAt &&
          (
            request.resource.data.sharedResultsOpened == resource.data.sharedResultsOpened ||
            (
              resource.data.sharedResultsOpened != true &&
              request.resource.data.sharedResultsOpened == true &&
              resource.data.resultsUnlocked == true &&
              request.resource.data.sharedResultsOpenedBy == request.auth.uid
            )
          ) &&
          request.resource.data.status != 'joint_active'
        )
      ));

      match /ownershipCategories/{categoryKey} {
        allow read, create, update: if (isActiveAccount() && isFamilyMember(familyId)) || isAdmin();
        allow delete: if false;
      }

      match /ownershipCards/{cardId} {
        allow read, create, update: if (isActiveAccount() && isFamilyMember(familyId)) || isAdmin();
        allow delete: if false;
      }

      match /auditEvents/{eventId} {
        allow read: if (isActiveAccount() && isFamilyMember(familyId)) || isAdmin();
        allow create: if isActiveAccount() && isFamilyMember(familyId);
        allow update, delete: if false;
      }

      match /teamCheckPreparations/{docId} {
        allow read, create, update: if (isActiveAccount() && isFamilyMember(familyId)) || isAdmin();
        allow delete: if isAdmin();
      }

      match /teamCheckRecords/{recordId} {
        allow read, create, update: if (isActiveAccount() && isFamilyMember(familyId)) || isAdmin();
        allow delete: if isAdmin();
      }

      match /tasks/{taskId} {
        allow read: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser() && taskVisibleToCurrentUser();
        allow create, update, delete: if isActiveAccount()
          && isFamilyMember(familyId)
          && isSuperuser()
          && taskVisibleToCurrentUserInRequest();
      }

      match /taskDelegations/{delegationId} {
        allow read, create, update, delete: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser();
      }

      match /taskOverrides/{overrideId} {
        allow read, create, update, delete: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser();
      }

      match /users/{userId} {
        allow read: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser() && request.auth.uid == userId;
        allow create, update, delete: if false;

        match /conversationStates/{taskId} {
          allow read: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser() && request.auth.uid == userId;
          allow create, update, delete: if false;
        }

        match /inboxEntries/{taskId} {
          allow read: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser() && request.auth.uid == userId;
          allow create, update, delete: if false;
        }

        match /uiState/{docId} {
          allow read: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser() && request.auth.uid == userId;
          allow create, update, delete: if false;
        }
      }

      match /taskThreads/{threadId} {
        allow read: if isActiveAccount()
          && isFamilyMember(familyId)
          && isSuperuser()
          && (
            !('participantUserIds' in resource.data) ||
            resource.data.participantUserIds.hasAny([request.auth.uid])
          );
        allow create, update, delete: if false;

        match /messages/{messageId} {
          allow read: if isActiveAccount()
            && isFamilyMember(familyId)
            && isSuperuser()
            && (
              !('visibleToUserIds' in resource.data) ||
              resource.data.visibleToUserIds.hasAny([request.auth.uid])
            );
          allow create: if isActiveAccount()
            && isFamilyMember(familyId)
            && isSuperuser()
            && request.resource.data.type == 'user_message'
            && request.resource.data.senderUserId == request.auth.uid;
          allow update, delete: if false;
        }

        match /readState/{userId} {
          allow read: if isActiveAccount() && isFamilyMember(familyId) && isSuperuser();
          allow create, update, delete: if false;
        }
      }
    }

    match /taskPackageTemplates/{templateId} {
      allow read: if isActiveAccount();
      allow create, update, delete: if isAdmin();
    }

    match /invitations/{invitationId} {
      allow read: if true;
      allow create, update: if isActiveAccount() && request.resource.data.initiatorUserId == request.auth.uid;
    }

    match /quizSessions/{sessionId} {
      allow read, create: if true;
      allow update: if true;
    }

    match /quizResults/{resultId} {
      allow read: if isAdmin() || (isActiveAccount() && (
        resource.data.userId == request.auth.uid ||
        (
          isFamilyMember(resource.data.familyId) &&
          familyResultsUnlocked(resource.data.familyId) &&
          familySharedResultsOpened(resource.data.familyId)
        )
      ));
      allow create, update: if (isActiveAccount() && request.resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /jointResults/{jointResultId} {
      allow read: if isAdmin() || (isActiveAccount() && (
        isFamilyMember(resource.data.familyId) && familyResultsUnlocked(resource.data.familyId)
        && familySharedResultsOpened(resource.data.familyId)
      ));
      allow create: if (isActiveAccount() &&
        isFamilyMember(request.resource.data.familyId) &&
        familyDoc(request.resource.data.familyId).data.initiatorUserId == request.auth.uid) || isAdmin();
      allow update: if isAdmin() || (isActiveAccount() &&
        isFamilyMember(resource.data.familyId) &&
        familyDoc(resource.data.familyId).data.initiatorUserId == request.auth.uid);
    }

    match /questionPools/{docId} {
      allow read: if isActiveAccount();
      allow create, update, delete: if isAdmin();
    }

    match /templates/{docId} {
      allow read: if isActiveAccount();
      allow create, update, delete: if isAdmin();
    }

    match /userResults/{userId} {
      allow read, create, update: if (isSelf(userId) && isActiveAccount()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /mailLogs/{mailLogId} {
      allow create: if isActiveAccount();
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
